# ==============================================
# email-service - .env.example
# ==============================================

# Runtime
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (preferencial)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_service

# PostgreSQL (fallback se DATABASE_URL nao for informado)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=email_service
DB_USER=postgres
DB_PASSWORD=postgres

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Integracao REST interna com garantia-service
GARANTIA_SERVICE_URL=http://localhost:3000/api
GARANTIA_SERVICE_TIMEOUT_MS=3000

# Fallback de credencial SMTP para worker outbound
# Observacao: o padrao recomendado e usar auth_secret_ref por conta
# no formato usuario:senha. Estas variaveis sao fallback global.
SMTP_USER=
SMTP_PASS=
